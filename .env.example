# Ethereum RPC URL
RPC_URL=https://ethereum-public.nodies.app/
# Private RPC for fast, protected mining submissions (Flashbots/MEV-Blocker)
TX_RPC_URL=https://rpc.flashbots.net/fast

# Your wallet private key (WITH 0x prefix)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Max gas price in gwei (tx skipped if gas is higher)
MAX_GAS_PRICE_GWEI=4

# Priority fee (Tip) given to the block builder to win the block-cap race
TIP_GWEI=2

# CUDA kernel parameters (tune for your GPU)
# RTX 5070: try CUDA_GRID=512, CUDA_BLOCKS=256, CUDA_NPT=128
CUDA_GRID=1024
CUDA_BLOCKS=256
CUDA_NPT=256

# Epoch change polling interval (ms)
EPOCH_POLL_MS=30000

# Path to CUDA miner binary
CUDA_BINARY=./cuda/miner
